{
  "steps": {
    "install-frontend": {
      "commands": [
        "cd frontend && npm install && npm run build"
      ]
    },
    "install": {
      "commands": [
        "python -m venv /app/.venv",
        "pip install -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "cmd": "gunicorn backend.app:app --bind 0.0.0.0:$PORT"
  }
}